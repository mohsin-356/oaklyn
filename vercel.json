{
  "version": 2,
  "builds": [
    {
      "src": "api/[[...path]].js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/vite"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/((?!api/).*)", "dest": "/index.html" }
  ]
}
